<?xml version="1.0"?>
<robot xmlns:xacro="http://wiki.ros.org/xacro">

  <xacro:macro name="parallel_gripper" params="prefix">
    
    <!-- Extract robot name from prefix (e.g., "arm1/" -> "arm1") -->
    <xacro:property name="robot_name" value="${prefix.rstrip('/')}"/>
    
    <!-- Gripper parameters -->
    <xacro:property name="finger_length" value="0.05"/>
    <xacro:property name="finger_width" value="0.03"/>
    <xacro:property name="finger_thickness" value="0.01"/>
    <xacro:property name="max_opening" value="0.07"/>  <!-- 7cm open gap (±0.04 origins, 0.01 finger thickness) -->

    <!-- ================= LINKS ================= -->

    <link name="${prefix}gripper_base">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.095 0.03 0.01"/>
        </geometry>
        <material name="gripper_blue">
          <color rgba="0 0 1 1"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <box size="0.095 0.03 0.01"/>
        </geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0.01" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
      </inertial>
    </link>

    <link name="${prefix}left_finger">
      <visual>
        <origin xyz="0 0 ${finger_length/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${finger_thickness} ${finger_width} ${finger_length}"/>
        </geometry>
        <material name="finger_orange">
          <color rgba="1.0 0.5 0.0 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 ${finger_length/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${finger_thickness} ${finger_width} ${finger_length}"/>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>100000</kp>
              <kd>10</kd>
              <max_vel>0.01</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <inertial>
        <origin xyz="0 0 ${finger_length/2}" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>

    <link name="${prefix}right_finger">
      <visual>
        <origin xyz="0 0 ${finger_length/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${finger_thickness} ${finger_width} ${finger_length}"/>
        </geometry>
        <material name="finger_orange">
          <color rgba="1.0 0.5 0.0 1.0"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 0 ${finger_length/2}" rpy="0 0 0"/>
        <geometry>
          <box size="${finger_thickness} ${finger_width} ${finger_length}"/>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.5</mu>
              <mu2>1.5</mu2>
            </ode>
          </friction>
          <contact>
            <ode>
              <kp>100000</kp>
              <kd>10</kd>
              <max_vel>0.01</max_vel>
              <min_depth>0.001</min_depth>
            </ode>
          </contact>
        </surface>
      </collision>
      <inertial>
        <origin xyz="0 0 ${finger_length/2}" rpy="0 0 0"/>
        <mass value="0.01"/>
        <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00001" iyz="0" izz="0.00001"/>
      </inertial>
    </link>

    <!-- ================= JOINTS ================= -->

    <joint name="${prefix}gripper_base_joint" type="fixed">
      <parent link="${prefix}ee_link"/>
      <child link="${prefix}gripper_base"/>
    </joint>

    <!-- Left finger slides inward (+X) from left edge of base to close -->
    <!-- position=0.0 → open (at base edge), position=0.035 → closed (at center) -->
    <joint name="${prefix}left_finger_joint" type="prismatic">
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}left_finger"/>
      <origin xyz="-0.04 0 0.005" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="0.0" upper="0.035" effort="50" velocity="1.0"/>
      <dynamics damping="0.05" friction="0.01"/>
    </joint>

    <!-- Right finger slides inward (-X) from right edge of base to close -->
    <!-- position=0.0 → open (at base edge), position=0.035 → closed (at center) -->
    <joint name="${prefix}right_finger_joint" type="prismatic">
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}right_finger"/>
      <origin xyz="0.04 0 0.005" rpy="0 0 0"/>
      <axis xyz="-1 0 0"/>
      <mimic joint="${prefix}left_finger_joint" multiplier="1.0" offset="0.0"/>
      <limit lower="0.0" upper="0.035" effort="50" velocity="1.0"/>
      <dynamics damping="0.05" friction="0.01"/>
    </joint>

    <!-- ros2_control for the finger joint is merged into the arm's ros2_control block
         in ur_ros2_control.xacro so all joints share the same GazeboSimSystem hardware -->

    <!-- ================= GAZEBO ================= -->

    <gazebo reference="${prefix}gripper_base">
      <material>Gazebo/Blue</material>
    </gazebo>

     <gazebo reference="${prefix}left_finger">
      <material>Gazebo/Orange</material>
    </gazebo>

    <gazebo reference="${prefix}right_finger">
      <material>Gazebo/Orange</material>
    </gazebo>

    <!-- Gazebo joint properties for gripper fingers (DART physics) -->
    <gazebo reference="${prefix}left_finger_joint">
      <provideFeedback>true</provideFeedback>
    </gazebo>

    <gazebo reference="${prefix}right_finger_joint">
      <provideFeedback>true</provideFeedback>
    </gazebo>

  </xacro:macro>

</robot>
